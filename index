    <script>
        function navigateToView(viewKeyId) {
            document.getElementById('view-homepage').classList.replace('block', 'hidden');
            document.getElementById('view-essentials').classList.replace('block', 'hidden');
            document.getElementById('view-benchmark').classList.replace('block', 'hidden');
            document.getElementById('view-collateral').classList.replace('block', 'hidden');
            
            const activeView = document.getElementById('view-' + (viewKeyId === 'benchmark' ? 'benchmark' : viewKeyId));
            if (activeView) {
                activeView.classList.replace('hidden', 'block');
            }
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function toggleDropdownPane(targetPaneId) {
            const pane = document.getElementById('panel-' + targetPaneId);
            const chevron = document.getElementById('chevron-' + targetPaneId);
            if (pane.classList.contains('open')) {
                pane.classList.remove('open');
                chevron.classList.remove('open');
            } else {
                pane.classList.add('open');
                chevron.classList.add('open');
            }
        }

        function scrollToMenu(categoryKey) {
            const pane = document.getElementById('panel-' + categoryKey);
            const chevron = document.getElementById('chevron-' + categoryKey);
            if (pane && !pane.classList.contains('open')) {
                pane.classList.add('open');
                chevron.classList.add('open');
            }
            document.getElementById('navigator-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        const marketingBtn = document.getElementById('marketingMenuBtn');
        const marketingDropdown = document.getElementById('marketingMenuDropdown');

        marketingBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            marketingDropdown.classList.toggle('hidden');
        });

        document.addEventListener('click', () => {
            marketingDropdown.classList.add('hidden');
        });
    </script>
